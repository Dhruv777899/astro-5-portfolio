---
const stats = [
  { num: '3+', label: 'Years Experience', delay: 1 },
  { num: '20+', label: 'Projects Shipped', delay: 2 },
  { num: '6', label: 'Major Clients', delay: 3 },
  { num: '∞', label: 'Problems Solved', delay: 4 },
];
---

<section id="home" class="relative overflow-hidden px-20 py-30 min-h-screen flex flex-col justify-center pt-15 bg-base max-lg:px-10 max-sm:px-6">
  <!-- Background orbs -->
  <div class="orb w-[500px] h-[500px] bg-[radial-gradient(circle,rgba(232,98,42,0.18)_0%,transparent_70%)] -top-25 -right-25"></div>
  <div class="orb w-[300px] h-[300px] bg-[radial-gradient(circle,rgba(240,160,64,0.12)_0%,transparent_70%)] bottom-12 left-50"></div>

  <!-- Floating shapes -->
  <span class="shape circle" style="top:12%;left:8%;animation-delay:0s"></span>
  <span class="shape ring" style="top:25%;left:18%;animation-delay:1.2s"></span>
  <span class="shape dash" style="top:18%;left:38%;animation-delay:0.5s"></span>
  <span class="shape" style="top:60%;left:6%;animation-delay:2s">×</span>
  <span class="shape" style="top:40%;left:28%;animation-delay:1s">+</span>
  <span class="shape" style="top:75%;left:15%;animation-delay:3s">›</span>
  <span class="shape circle" style="top:80%;left:40%;animation-delay:0.8s"></span>
  <span class="shape ring" style="top:55%;right:22%;animation-delay:2.5s"></span>
  <span class="shape" style="top:20%;right:10%;animation-delay:1.5s">×</span>
  <span class="shape dash" style="top:70%;right:15%;animation-delay:0.3s"></span>
  <span class="shape" style="top:88%;right:8%;animation-delay:1.8s">+</span>

  <div class="grid grid-cols-[1fr_380px] gap-15 items-center relative z-2 max-lg:grid-cols-1">
    <div>
      <span class="hero-label text-[11px] font-semibold tracking-[0.25em] uppercase text-accent mb-5 block reveal">
        Full-Stack Developer &amp; Designer
      </span>
      <h1 class="hero-name font-heading text-[clamp(80px,11vw,140px)] leading-[0.9] text-text tracking-tight mb-7 reveal reveal-delay-1">
        <span class="block">DHRUV</span>
        <span class="block">PRAJAPATI</span>
      </h1>
      <p class="font-serif italic text-xl text-text-muted leading-relaxed max-w-[520px] mb-12 reveal reveal-delay-2">
        "I turn tangled briefs into clean, working things —<br />where design meets engineering."
      </p>
      <div class="flex gap-6 items-center reveal reveal-delay-3">
        <a href="#work" class="btn-primary bg-accent text-base border-none py-3.5 px-8 font-body text-[13px] font-semibold tracking-[0.1em] uppercase no-underline cursor-none transition-all hover:bg-accent-light hover:shadow-[0_0_30px_rgba(232,98,42,0.4)] hover:-translate-y-0.5">
          View My Work
        </a>
        <a href="#contact" class="text-text text-sm font-medium no-underline flex items-center gap-2 transition-all hover:text-accent hover:gap-3">
          Let's Talk <span>→</span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 max-lg:grid-cols-4 max-sm:grid-cols-2">
      {stats.map((stat) => (
        <div class={`card-line bg-surface border border-accent/15 py-6 px-5 relative overflow-hidden transition-all hover:border-accent/50 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(232,98,42,0.15)] reveal reveal-delay-${stat.delay}`}>
          <div class="font-heading text-[52px] text-accent leading-none mb-1.5">{stat.num}</div>
          <div class="text-[11px] text-text-dim tracking-[0.1em] uppercase">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-2">
    <span class="text-[9px] tracking-[0.2em] uppercase text-text-dim">SCROLL</span>
    <div class="w-px h-12 bg-gradient-to-b from-accent/60 to-transparent animate-[scrollBounce_2s_ease-in-out_infinite]"></div>
  </div>

  <div class="section-num">01</div>
</section>
