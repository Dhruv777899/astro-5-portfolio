---
const filters = [
  { label: 'ALL', value: 'all' },
  { label: 'WEB DEV', value: 'web-dev' },
  { label: 'CMS', value: 'cms' },
  { label: 'FRONT-END', value: 'front-end' },
];

const projects = [
  {
    num: '01',
    type: 'Laravel · Headless WordPress',
    name: 'Hollywood<br>Suite Website',
    problem: '"A media platform choked by N+1 queries and a cache system that couldn\'t keep up with a national broadcast schedule."',
    did: 'Resolved N+1 database queries across multiple controllers, built a per-item cache invalidation system tied to post_modified_gmt timestamps, implemented a proactive WarmApiCache artisan command across timezones, and integrated Meilisearch with custom sync logic.',
    stack: ['Laravel', 'Corcel/ACF', 'Meilisearch', 'GSAP', 'CloudFront'],
    category: 'web-dev front-end',
    featured: true,
  },
  {
    num: '02',
    type: 'Vue.js · WordPress/ACF',
    name: 'AMO Elections<br>Resource Hub',
    problem: '"A sprawling elections resource tool that Ontario municipal clerks couldn\'t navigate — and couldn\'t trust to show their jurisdiction."',
    did: 'Built a Vue-based filterable resource list, a proximity + jurisdiction-based clerk office directory using Ontario GeoHub boundary data, full WCAG/AODA accessibility audit and remediation, and GTM/GA4 analytics integration.',
    stack: ['Vue.js', 'WordPress', 'ACF', 'Google Maps API', 'GTM'],
    category: 'web-dev front-end',
    featured: false,
  },
  {
    num: '03',
    type: 'Craft CMS · HubSpot',
    name: 'Blue Cross<br>Health Website',
    problem: '"An enterprise health site with declining performance scores, a broken CDN, and a multilingual HubSpot integration that wouldn\'t cooperate."',
    did: 'Resolved LCP issues through eager loading and N+1 fixes, migrated CDN from imgix to AWS CloudFront, embedded HubSpot forms across English and French domains, and built custom CKEditor 5 plugins for quote and column content blocks.',
    stack: ['Craft CMS', 'Sprout SEO', 'HubSpot', 'CloudFront', 'CKEditor 5'],
    category: 'cms',
    featured: false,
  },
  {
    num: '04',
    type: 'Astro 5 · Cloudflare Pages',
    name: 'Alberta Referendum<br>Microsite',
    problem: '"A 6-page government microsite with a hard political deadline, built on a brand-new stack under agency time constraints."',
    did: 'Architected and built the full site using Astro 5, Vue 3, and Tailwind 4 on Cloudflare Pages. Wrote the full operational Notion doc covering dev → staging → launch → takedown lifecycle.',
    stack: ['Astro 5', 'Vue 3', 'Tailwind 4', 'Cloudflare Pages'],
    category: 'front-end web-dev',
    featured: false,
  },
];
---

<section id="work" class="relative overflow-hidden py-30 bg-base-alt">
  <span class="shape ring" style="top:5%;left:3%;animation-delay:1s"></span>
  <span class="shape" style="top:30%;right:3%;animation-delay:0.5s">›</span>
  <span class="shape circle" style="bottom:5%;left:8%;animation-delay:1.8s"></span>
  <span class="shape dash" style="bottom:12%;right:5%;animation-delay:0.2s"></span>

  <div class="container">
  <div class="mb-15 reveal">
    <h2 class="font-heading text-[56px] text-text tracking-wide">SELECTED WORK</h2>
    <p class="text-text-dim text-[15px] mt-2">Real problems, real solutions, real clients.</p>
  </div>

  <div class="flex gap-1 mb-12 relative z-2 reveal">
    {filters.map((f, i) => (
      <button
        class:list={[
          'filter-btn bg-none border-none font-body text-xs font-semibold tracking-[0.15em] uppercase text-text-dim py-2.5 px-5 cursor-none relative transition-colors hover:text-text',
          i === 0 && 'active text-accent',
        ]}
        data-filter={f.value}
      >
        {f.label}
      </button>
    ))}
  </div>

  <div class="work-grid grid grid-cols-2 gap-6 relative z-2 max-lg:grid-cols-1">
    {projects.map((project, i) => (
      <div
        class:list={[
          project.featured && 'col-span-2 max-lg:col-span-1',
          'reveal',
          i > 0 && `reveal-delay-${i}`,
        ]}
      >
      <div
        class:list={[
          'project-card card-line bg-surface-alt border border-accent/12 py-9 px-8 relative overflow-hidden transition-all flex flex-col',
          'hover:border-accent/45 hover:-translate-y-1 hover:shadow-[0_20px_60px_rgba(232,98,42,0.12)]'
        ]}
        data-category={project.category}
      >
        <span class="absolute top-5 right-6 font-heading text-[80px] text-text opacity-[0.04] leading-none pointer-events-none">
          {project.num}
        </span>

        {project.featured ? (
          <div class="grid grid-cols-2 gap-10 max-lg:grid-cols-1 max-lg:gap-6">
            <div>
              <div class="text-[10px] font-semibold tracking-[0.2em] uppercase text-accent mb-3">{project.type}</div>
              <div class="font-heading text-5xl text-text tracking-tight mb-5 leading-none max-lg:text-4xl" set:html={project.name} />
              <p class="font-serif italic text-base text-text-muted leading-relaxed">{project.problem}</p>
            </div>
            <div>
              <div>
                <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase text-accent-light mb-2">What I Did</h4>
                <p class="text-[13px] text-text-dim leading-[1.7] mb-5">{project.did}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                {project.stack.map((tag) => (
                  <span class="text-[10px] font-medium tracking-[0.1em] uppercase text-text-dim border border-text-dim/25 py-1 px-3 transition-colors">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <>
            <div class="text-[10px] font-semibold tracking-[0.2em] uppercase text-accent mb-3">{project.type}</div>
            <div class="font-heading text-4xl text-text tracking-tight mb-5 leading-none" set:html={project.name} />
            <p class="font-serif italic text-base text-text-muted leading-relaxed mb-5 flex-1">{project.problem}</p>
            <div>
              <h4 class="text-[10px] font-semibold tracking-[0.2em] uppercase text-accent-light mb-2">What I Did</h4>
              <p class="text-[13px] text-text-dim leading-[1.7] mb-5">{project.did}</p>
            </div>
            <div class="flex flex-wrap gap-2">
              {project.stack.map((tag) => (
                <span class="text-[10px] font-medium tracking-[0.1em] uppercase text-text-dim border border-text-dim/25 py-1 px-3 transition-colors">{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
      </div>
    ))}
  </div>
  </div><!-- /container -->

  <div class="section-num">04</div>
</section>

<script>
  import { initWorkFilter } from '../scripts/workFilter';
  initWorkFilter();
</script>
