---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Dhruv Prajapati — Full-Stack Developer & Designer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body>
  <!-- Custom Cursor -->
  <div id="cursor-dot"></div>
  <div id="cursor-ring"></div>

  <slot />

  <script>
    import { initCursor } from '../scripts/cursor';
    import { initScrollReveal, initSidebarNav } from '../scripts/scroll';

    initCursor();
    initScrollReveal();
    initSidebarNav();
  </script>
</body>
</html>
